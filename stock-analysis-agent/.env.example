ANTHROPIC_API_KEY=sk-ant-...
SCHWAB_APP_KEY=your_schwab_app_key
SCHWAB_APP_SECRET=your_schwab_app_secret
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
BRAVE_API_KEY=your_brave_api_key

# External API access (ChatGPT Actions, Gemini, Grok)
# Leave unset for open local dev. Set to a strong random string to require
# X-API-Key header on all requests. /health is always exempt.
AGENT_API_KEY=

# Figma API (for design spec extraction → React code generation)
FIGMA_TOKEN=figd_your-token-here

# SQLite trade memory database path (local dev)
# In Azure Container Apps, mount a persistent volume and set this to the mount path.
DB_PATH=/path/to/data/trading_memory.db

# Vector store backend
# "chroma" — local ChromaDB (default for dev); persists to ~/.chromadb/stock_copilot/
# "azure"  — Azure AI Search (for production deployment)
VECTOR_BACKEND=chroma

# Azure AI Search (required when VECTOR_BACKEND=azure)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_admin_key
AZURE_SEARCH_INDEX=stock-copilot

# Anthropic Managed Agents (populated automatically by scripts/register_agents.py)
# Do not edit manually — managed via .agent_registry.json
# ANTHROPIC_API_KEY is already set above and is shared by all agents
